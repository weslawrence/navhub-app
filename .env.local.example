# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Xero ────────────────────────────────────────────────────
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=https://app.navhub.co/api/xero/callback

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://app.navhub.co
NEXT_PUBLIC_APP_NAME=NavHub

# ── Cron ────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
CRON_SECRET=

# ── Agent Encryption ─────────────────────────────────────────
# 32-byte hex string — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be added to Vercel environment variables before agents will work
NAVHUB_ENCRYPTION_KEY=

# ── Anthropic ────────────────────────────────────────────────
# From console.anthropic.com
# MUST be added to Vercel environment variables before agents will work
ANTHROPIC_API_KEY=

# ── Resend (email) ───────────────────────────────────────────
# From resend.com
RESEND_API_KEY=
RESEND_FROM_DOMAIN=navhub.co

# ── Optional — user-supplied via agent credentials ───────────
# OPENAI_API_KEY=   ← stored per-agent as encrypted credential, not here
